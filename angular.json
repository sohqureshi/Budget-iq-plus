{
  "$schema": "https://angular.io/cli/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "budget-iq-plus": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/budget-iq-plus",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": "src/polyfills.ts",
            "tsConfig": "tsconfig.json",
            "assets": [
              "src/assets"
            ],
            "styles": [
              "src/styles.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true,
              "baseHref": "/Budget-iq-plus/",
              "deployUrl": "/Budget-iq-plus/"
            }
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "budget-iq-plus:build"
          },
          "configurations": {
            "production": {
              "browserTarget": "budget-iq-plus:build:production"
            }
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
